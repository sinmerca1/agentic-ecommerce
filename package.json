{
  "name": "agentic-ecommerce",
  "version": "1.0.0",
  "description": "An agentic e-commerce application with LLM agents",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "docker:build": "docker build -t agentic-ecommerce .",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down"
  },
  "keywords": [
    "ecommerce",
    "agents",
    "langgraph",
    "ollama",
    "elasticsearch"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.37",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.12.0",
    "@langchain/core": "^1.0.0",
    "@langchain/langgraph": "^0.0.32",
    "@langchain/ollama": "^1.2.6",
    "axios": "^1.6.5",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "pino": "^8.17.2",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  }
}
